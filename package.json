{
  "name": "vaastu-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:frontend": "vite",
    "dev:backend": "nodemon --watch backend --ext py --exec \"python backend/app.py\"",
    "dev:full": "concurrently -k -n REACT,FLASK -c green,blue \"npm run dev:frontend\" \"npm run dev:backend\"",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "prod": "npm run build && python backend/app.py"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "vite": "^7.2.7"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.14"
  }
}